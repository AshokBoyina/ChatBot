@page "/"

<PageTitle>NASS AI Chatbot</PageTitle>

<div class="nass-home">
    <div class="nass-logo-row">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" class="nass-icon">
            <circle cx="24" cy="24" r="22" fill="#336600" />
            <path d="M14 34c0-5.5 4.5-10 10-10s10 4.5 10 10" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/>
            <circle cx="24" cy="18" r="5" fill="#fff" />
        </svg>
        <div>
            <div class="nass-title">USDA · NASS</div>
            <div class="nass-subtitle">National Agricultural Statistics Service</div>
        </div>
    </div>
    <h1>Sample AI Chatbot for NASS</h1>
    <p>Click the chat button in the <strong>bottom-right corner</strong> to get started.</p>
</div>

<style>
    .nass-home {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 4rem);
        text-align: center;
        gap: 0.75rem;
    }

    .nass-logo-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .nass-icon { width: 52px; height: 52px; flex-shrink: 0; }

    .nass-title {
        font-size: 1rem;
        font-weight: 700;
        color: #336600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .nass-subtitle {
        font-size: 0.78rem;
        color: #4b5563;
        margin-top: 2px;
    }

    .nass-home h1 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a2e0e;
        margin: 0;
    }

    .nass-home p {
        color: #4b5563;
        font-size: 0.95rem;
        margin: 0;
    }

    .nass-home strong { color: #336600; }
</style>
