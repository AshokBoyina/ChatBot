@rendermode InteractiveServer
@inject IChatService FoundryService
@inject IJSRuntime JS
@implements IDisposable

<div class="cw-container">

    @* ── Floating bubble (collapsed) ── *@
    @if (!_isOpen)
    {
        <div class="cw-bubble-wrap">

            @* ── Compact name pill above the bubble ── *@
            <div class="cw-id-pill" @onclick="OpenChat" title="@($"Chat with {FoundryService.AssistantName}")">
                <img class="cw-pill-avatar" aria-hidden="true" alt=""
                     src="data:image/svg+xml,%3Csvg viewBox='0 0 28 28' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='14' cy='14' r='14' fill='%231f4d00'/%3E%3Cellipse cx='14' cy='12' rx='7.5' ry='8.5' fill='%231A0A00'/%3E%3Cellipse cx='14' cy='13.5' rx='6' ry='6.5' fill='%23FCCBA1'/%3E%3Cpath d='M6.5 12 Q7 4 14 4.5 Q21 4 21.5 12 Q19 7 14 7.5 Q9 7 6.5 12Z' fill='%231A0A00'/%3E%3Cpath d='M8 15 Q6.5 19 7.5 23 Q8.5 19.5 8.5 17Z' fill='%231A0A00'/%3E%3Cpath d='M20 15 Q21.5 19 20.5 23 Q19.5 19.5 19.5 17Z' fill='%231A0A00'/%3E%3Cellipse cx='11' cy='13' rx='1.5' ry='1.4' fill='white'/%3E%3Cellipse cx='17' cy='13' rx='1.5' ry='1.4' fill='white'/%3E%3Ccircle cx='11.3' cy='13.2' r='0.9' fill='%231A0A00'/%3E%3Ccircle cx='17.3' cy='13.2' r='0.9' fill='%231A0A00'/%3E%3Ccircle cx='11.6' cy='12.8' r='0.35' fill='white'/%3E%3Ccircle cx='17.6' cy='12.8' r='0.35' fill='white'/%3E%3Cellipse cx='9' cy='15.5' rx='2' ry='1.2' fill='%23F4897A' opacity='0.3'/%3E%3Cellipse cx='19' cy='15.5' rx='2' ry='1.2' fill='%23F4897A' opacity='0.3'/%3E%3Cpath d='M10.5 17 Q14 19.5 17.5 17' stroke='%23C45A3A' stroke-width='1' fill='none' stroke-linecap='round'/%3E%3Cpath d='M7 13 Q7 6 14 6 Q21 6 21 13' stroke='%237EC63B' stroke-width='1.6' fill='none' stroke-linecap='round'/%3E%3Crect x='4.5' y='12' width='4' height='5' rx='2' fill='%23336600'/%3E%3Crect x='19.5' y='12' width='4' height='5' rx='2' fill='%23336600'/%3E%3Cpath d='M22.5 16 Q24.5 18 24 20.5' stroke='%237EC63B' stroke-width='1.2' fill='none' stroke-linecap='round'/%3E%3Ccircle cx='24' cy='20.8' r='1.2' fill='%237EC63B'/%3E%3C/svg%3E" />
                <span class="cw-pill-name">@FoundryService.AssistantName</span>
                <span class="cw-pill-dot" aria-hidden="true"></span>
            </div>

            <button class="cw-bubble @(_hasUnread ? "cw-bubble--pulse" : "")"
                    @onclick="OpenChat"
                    title="@($"Open {FoundryService.AssistantName}")"
                    aria-label="@($"Open {FoundryService.AssistantName}")">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg>
                @if (_hasUnread)
                {
                    <span class="cw-unread-dot" aria-hidden="true"></span>
                }
            </button>

        </div>
    }

    @* ── Chat panel (expanded) ── *@
    @if (_isOpen)
    {
        <div class="cw-panel" role="dialog" aria-label="@FoundryService.AssistantName">

            @* ── Header ── *@
            <div class="cw-header">
                <div class="cw-header-left">
                    <div class="cw-avatar" aria-hidden="true">
                        <img alt="" src="data:image/svg+xml,%3Csvg viewBox='0 0 28 28' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='14' cy='14' r='14' fill='%231f4d00'/%3E%3Cellipse cx='14' cy='12' rx='7.5' ry='8.5' fill='%231A0A00'/%3E%3Cellipse cx='14' cy='13.5' rx='6' ry='6.5' fill='%23FCCBA1'/%3E%3Cpath d='M6.5 12 Q7 4 14 4.5 Q21 4 21.5 12 Q19 7 14 7.5 Q9 7 6.5 12Z' fill='%231A0A00'/%3E%3Cpath d='M8 15 Q6.5 19 7.5 23 Q8.5 19.5 8.5 17Z' fill='%231A0A00'/%3E%3Cpath d='M20 15 Q21.5 19 20.5 23 Q19.5 19.5 19.5 17Z' fill='%231A0A00'/%3E%3Cellipse cx='11' cy='13' rx='1.5' ry='1.4' fill='white'/%3E%3Cellipse cx='17' cy='13' rx='1.5' ry='1.4' fill='white'/%3E%3Ccircle cx='11.3' cy='13.2' r='0.9' fill='%231A0A00'/%3E%3Ccircle cx='17.3' cy='13.2' r='0.9' fill='%231A0A00'/%3E%3Ccircle cx='11.6' cy='12.8' r='0.35' fill='white'/%3E%3Ccircle cx='17.6' cy='12.8' r='0.35' fill='white'/%3E%3Cellipse cx='9' cy='15.5' rx='2' ry='1.2' fill='%23F4897A' opacity='0.3'/%3E%3Cellipse cx='19' cy='15.5' rx='2' ry='1.2' fill='%23F4897A' opacity='0.3'/%3E%3Cpath d='M10.5 17 Q14 19.5 17.5 17' stroke='%23C45A3A' stroke-width='1' fill='none' stroke-linecap='round'/%3E%3Cpath d='M7 13 Q7 6 14 6 Q21 6 21 13' stroke='%237EC63B' stroke-width='1.6' fill='none' stroke-linecap='round'/%3E%3Crect x='4.5' y='12' width='4' height='5' rx='2' fill='%23336600'/%3E%3Crect x='19.5' y='12' width='4' height='5' rx='2' fill='%23336600'/%3E%3Cpath d='M22.5 16 Q24.5 18 24 20.5' stroke='%237EC63B' stroke-width='1.2' fill='none' stroke-linecap='round'/%3E%3Ccircle cx='24' cy='20.8' r='1.2' fill='%237EC63B'/%3E%3C/svg%3E" style="width:100%;height:100%;border-radius:50%;display:block;" />
                    </div>
                    <div>
                        <div class="cw-bot-name">@FoundryService.AssistantName</div>
                        <div class="cw-bot-status">
                            @if (_isStreaming)
                            {
                                <span class="cw-dots"><span></span><span></span><span></span></span>
                                <span>Typing…</span>
                            }
                            else
                            {
                                <span class="cw-online-dot"></span>
                                <span>Online</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="cw-header-right">
                    @if (_apps.Count > 1)
                    {
                        <select class="cw-app-select"
                                @bind="_selectedAppId"
                                @bind:after="OnAppChanged"
                                title="Switch knowledge base"
                                aria-label="Switch knowledge base">
                            @foreach (var a in _apps)
                            {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                    }
                    <button class="cw-hdr-btn" @onclick="ClearChat" title="New conversation" aria-label="New conversation">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2">
                            <polyline points="1 4 1 10 7 10" />
                            <path d="M3.51 15a9 9 0 1 0 .49-3.51" />
                        </svg>
                    </button>
                    <button class="cw-hdr-btn" @onclick="CloseChat" title="Minimise" aria-label="Minimise chat">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18" />
                            <line x1="6" y1="6" x2="18" y2="18" />
                        </svg>
                    </button>
                </div>
            </div>



            @* ── Messages ── *@
            <div class="cw-messages" id="cw-messages">

                @* Welcome screen *@
                @if (_messages.Count == 0 && !_isStreaming)
                {
                    <div class="cw-welcome">
                        <div class="cw-welcome-emoji">👋</div>
                        <p>Hi! Ask me anything about the selected knowledge base.</p>
                        <div class="cw-chips">
                            @foreach (var p in _starterPrompts)
                            {
                                <button class="cw-chip" @onclick="() => UseStarter(p)">@p</button>
                            }
                        </div>
                    </div>
                }

                @* Rendered messages *@
                @foreach (var msg in _messages)
                {
                    @if (msg.Role == "user")
                    {
                        <div class="cw-row cw-row--user">
                            <div class="cw-bubble-user">@msg.Content</div>
                            <time class="cw-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</time>
                        </div>
                    }
                    else
                    {
                        <div class="cw-row cw-row--bot">
                            <div class="cw-bot-row">
                                <span class="cw-mini-av" aria-hidden="true">@((MarkupString)_botAvatarSvg)</span>
                                <div class="cw-bubble-bot">@msg.Content</div>
                            </div>

                            @* Citations *@
                            @if (msg.Citations.Count > 0)
                            {
                                <div class="cw-cit-wrap">
                                    <button class="cw-cit-toggle"
                                            @onclick="() => ToggleCit(msg.Id)">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" width="11" height="11">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                            <polyline points="14 2 14 8 20 8" />
                                        </svg>
                                        @msg.Citations.Count source@(msg.Citations.Count != 1 ? "s" : "")
                                        <span class="cw-arrow @(_openCit.Contains(msg.Id) ? "cw-arrow--open" : "")">›</span>
                                    </button>

                                    @if (_openCit.Contains(msg.Id))
                                    {
                                        <ul class="cw-cit-list">
                                            @foreach (var c in msg.Citations)
                                            {
                                                <li class="cw-cit">
                                                    <span class="cw-cit-n">[@c.Index]</span>
                                                    @if (!string.IsNullOrEmpty(c.Url))
                                                    {
                                                        <a href="@c.Url" target="_blank" rel="noopener"
                                                           class="cw-cit-link" title="@c.Excerpt">@c.Title</a>
                                                    }
                                                    else
                                                    {
                                                        <span class="cw-cit-title" title="@c.Excerpt">@c.Title</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(c.FilePath))
                                                    {
                                                        <span class="cw-cit-path">@c.FilePath</span>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }

                            <time class="cw-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</time>
                        </div>
                    }
                }

                @* Live streaming reply *@
                @if (_isStreaming)
                {
                    <div class="cw-row cw-row--bot">
                        <div class="cw-bot-row">
                            <span class="cw-mini-av" aria-hidden="true">AI</span>
                            <div class="cw-bubble-bot cw-bubble-bot--live">
                                @_streamingText<span class="cw-cursor" aria-hidden="true">▋</span>
                            </div>
                        </div>
                    </div>
                }

                @* Error banner *@
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="cw-error" role="alert">⚠️ @_error</div>
                }
            </div>

            @* ── Input bar ── *@
            <div class="cw-input-bar">
                <textarea class="cw-input"
                          @bind="_inputText"
                          @bind:event="oninput"
                          @onkeydown="HandleKey"
                          placeholder="Ask me anything… (Enter to send)"
                          rows="1"
                          maxlength="4000"
                          aria-label="Your message"></textarea>
                <button class="cw-send"
                        @onclick="SendMessage"
                        disabled="@(string.IsNullOrWhiteSpace(_inputText) || _isStreaming)"
                        title="Send (Enter)"
                        aria-label="Send">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13" />
                        <polygon points="22 2 15 22 11 13 2 9 22 2" />
                    </svg>
                </button>
            </div>

            <div class="cw-footer">USDA &middot; National Agricultural Statistics Service</div>

        </div>
    }

</div>

@code {
    // ── Bot avatar — encoded as a data-URI so it renders reliably in any context
    // (inline SVG with shared gradient IDs breaks when the same SVG appears multiple times in the DOM)
    private const string _botAvatarSvg =
        """<img class="cw-mini-av-img" aria-hidden="true" alt="" src="data:image/svg+xml,%3Csvg viewBox='0 0 28 28' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='14' cy='14' r='14' fill='%231f4d00'/%3E%3Cellipse cx='14' cy='12' rx='7.5' ry='8.5' fill='%231A0A00'/%3E%3Cellipse cx='14' cy='13.5' rx='6' ry='6.5' fill='%23FCCBA1'/%3E%3Cpath d='M6.5 12 Q7 4 14 4.5 Q21 4 21.5 12 Q19 7 14 7.5 Q9 7 6.5 12Z' fill='%231A0A00'/%3E%3Cpath d='M8 15 Q6.5 19 7.5 23 Q8.5 19.5 8.5 17Z' fill='%231A0A00'/%3E%3Cpath d='M20 15 Q21.5 19 20.5 23 Q19.5 19.5 19.5 17Z' fill='%231A0A00'/%3E%3Cellipse cx='11' cy='13' rx='1.5' ry='1.4' fill='white'/%3E%3Cellipse cx='17' cy='13' rx='1.5' ry='1.4' fill='white'/%3E%3Ccircle cx='11.3' cy='13.2' r='0.9' fill='%231A0A00'/%3E%3Ccircle cx='17.3' cy='13.2' r='0.9' fill='%231A0A00'/%3E%3Ccircle cx='11.6' cy='12.8' r='0.35' fill='white'/%3E%3Ccircle cx='17.6' cy='12.8' r='0.35' fill='white'/%3E%3Cellipse cx='9' cy='15.5' rx='2' ry='1.2' fill='%23F4897A' opacity='0.3'/%3E%3Cellipse cx='19' cy='15.5' rx='2' ry='1.2' fill='%23F4897A' opacity='0.3'/%3E%3Cpath d='M10.5 17 Q14 19.5 17.5 17' stroke='%23C45A3A' stroke-width='1' fill='none' stroke-linecap='round'/%3E%3Cpath d='M7 13 Q7 6 14 6 Q21 6 21 13' stroke='%237EC63B' stroke-width='1.6' fill='none' stroke-linecap='round'/%3E%3Crect x='4.5' y='12' width='4' height='5' rx='2' fill='%23336600'/%3E%3Crect x='19.5' y='12' width='4' height='5' rx='2' fill='%23336600'/%3E%3Cpath d='M22.5 16 Q24.5 18 24 20.5' stroke='%237EC63B' stroke-width='1.2' fill='none' stroke-linecap='round'/%3E%3Ccircle cx='24' cy='20.8' r='1.2' fill='%237EC63B'/%3E%3C/svg%3E"/>""";

    // ── State ─────────────────────────────────────────────────────────────────
    private bool   _isOpen      = false;
    private bool   _isStreaming = false;
    private bool   _hasUnread   = false;
    private string _inputText   = string.Empty;
    private string _streamingText = string.Empty;
    private string? _error;

    private List<ChatMessage>    _messages = [];
    private List<RagApplication> _apps     = [];
    private HashSet<string>      _openCit  = [];
    private string               _selectedAppId = string.Empty;
    private RagApplication?      _selectedApp;

    private CancellationTokenSource? _cts;

    private readonly string[] _starterPrompts =
    [
        "What topics can you help me with?",
        "Give me a summary of available documents.",
        "What are the key policies I should know?"
    ];

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        _apps = FoundryService.GetApplications().ToList();
        if (_apps.Count > 0)
        {
            _selectedAppId = _apps[0].Id;
            _selectedApp   = _apps[0];
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }

    // ── Panel control ─────────────────────────────────────────────────────────
    private void OpenChat()  { _isOpen = true; _hasUnread = false; }
    private void CloseChat() { _isOpen = false; _cts?.Cancel(); }

    private void ClearChat()
    {
        _messages.Clear();
        _streamingText = string.Empty;
        _error = null;
        _openCit.Clear();
        _cts?.Cancel();
        _isStreaming = false;
    }

    // ── App selector ──────────────────────────────────────────────────────────
    private void OnAppChanged()
    {
        _selectedApp = _apps.FirstOrDefault(a => a.Id == _selectedAppId);
        ClearChat();
    }

    // ── Send logic ────────────────────────────────────────────────────────────
    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private async Task UseStarter(string text)
    {
        _inputText = text;
        await SendMessage();
    }

    private async Task SendMessage()
    {
        var text = _inputText.Trim();
        if (string.IsNullOrWhiteSpace(text) || _isStreaming) return;

        _inputText = string.Empty;
        _error     = null;

        // Snapshot history before appending new user message
        var history = _messages.ToList();

        _messages.Add(new ChatMessage { Role = "user", Content = text });
        _isStreaming   = true;
        _streamingText = string.Empty;

        await InvokeAsync(StateHasChanged);
        await ScrollBottomAsync();

        if (_selectedApp is null)
        {
            _error       = "No application selected.";
            _isStreaming = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        List<Citation> citations = [];

        try
        {
            await foreach (var chunk in FoundryService.StreamChatAsync(
                               _selectedApp, history, text, _cts.Token))
            {
                if (chunk.IsError)  { _error = chunk.Text; break; }
                if (chunk.IsDone)   { citations = chunk.Citations ?? []; break; }

                _streamingText += chunk.Text;
                await InvokeAsync(StateHasChanged);
                await ScrollBottomAsync();
            }
        }
        catch (OperationCanceledException) { /* user closed/cleared */ }
        catch (Exception ex) { _error = $"Unexpected error: {ex.Message}"; }
        finally
        {
            // If the API returned an error chunk, surface it as a bot message too
            // so it appears inline in the chat and can't be missed
            if (!string.IsNullOrEmpty(_error) && _streamingText.Length == 0)
            {
                _messages.Add(new ChatMessage
                {
                    Role    = "assistant",
                    Content = $"⚠️ {_error}"
                });
                _error = null; // shown in the message list — no need for the banner too
            }

            if (_streamingText.Length > 0)
            {
                _messages.Add(new ChatMessage
                {
                    Role      = "assistant",
                    Content   = _streamingText,
                    Citations = citations
                });
            }

            _streamingText = string.Empty;
            _isStreaming   = false;
            _cts           = null;

            if (!_isOpen) _hasUnread = true;

            await InvokeAsync(StateHasChanged);
            await ScrollBottomAsync();

            // Auto-summarise once the history grows beyond the threshold
            if (_messages.Count >= SummariseThreshold)
                await TrimHistoryAsync();
        }
    }

    // ── History summarisation ─────────────────────────────────────────────────

    /// <summary>
    /// When the message list reaches <see cref="SummariseThreshold"/>, the oldest
    /// messages (everything except the last <see cref="SummariseTailKeep"/> turns)
    /// are summarised by the API into a single context message.  This keeps the
    /// payload sent to the API small while preserving conversational context.
    /// </summary>
    private const int SummariseThreshold = 20;   // trigger at 20 messages
    private const int SummariseTailKeep  = 4;    // always keep the 4 most recent

    private async Task TrimHistoryAsync()
    {
        int headCount = _messages.Count - SummariseTailKeep;
        if (headCount <= 0) return;

        var toSummarise = _messages.Take(headCount).ToList();
        var tail        = _messages.Skip(headCount).ToList();

        string? summary;
        try
        {
            summary = await FoundryService.SummarizeAsync(toSummarise);
        }
        catch
        {
            return; // if summarisation fails just leave history as-is
        }

        if (string.IsNullOrWhiteSpace(summary)) return;

        _messages.Clear();
        _messages.Add(new ChatMessage
        {
            Role    = "assistant",
            Content = $"📋 **Earlier conversation summary**\n\n{summary}"
        });
        _messages.AddRange(tail);

        await InvokeAsync(StateHasChanged);
    }

    // ── Citations toggle ──────────────────────────────────────────────────────
    private void ToggleCit(string id)
    {
        if (!_openCit.Add(id)) _openCit.Remove(id);
    }

    // ── JS helpers ────────────────────────────────────────────────────────────
    private async Task ScrollBottomAsync()
    {
        try { await JS.InvokeVoidAsync("chatWidget.scrollToBottom", "cw-messages"); }
        catch { /* ignore pre-render */ }
    }
}
