@inject IChatService FoundryService
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cw-container">

    @* ── Name pill (collapsed) ── *@
    @if (!_isOpen)
    {
        <div class="cw-bubble-wrap">
            <div class="cw-id-pill @(_hasUnread ? "cw-id-pill--unread" : "")" @onclick="OpenChat" title="@($"Chat with {FoundryService.AssistantName}")">
                <div class="cw-pill-avatar-text" aria-hidden="true">AI</div>
                <span class="cw-pill-name">@FoundryService.AssistantName</span>
                <span class="cw-pill-dot" aria-hidden="true"></span>
                @if (_hasUnread) { <span class="cw-unread-dot" aria-hidden="true"></span> }
            </div>
        </div>
    }

    @* ── Chat panel (expanded) ── *@
    @if (_isOpen)
    {
        <div class="cw-panel" role="dialog" aria-label="@FoundryService.AssistantName">

            @* Header *@
            <div class="cw-header">
                <div class="cw-header-left">
                    <div class="cw-avatar" aria-hidden="true">
                        <div class="cw-avatar-text">AI</div>
                    </div>
                    <div>
                        <div class="cw-bot-name">@FoundryService.AssistantName</div>
                        <div class="cw-bot-status">
                            @if (_isStreaming)
                            {
                                <span class="cw-dots"><span></span><span></span><span></span></span>
                                <span>Typing&hellip;</span>
                            }
                            else
                            {
                                <span class="cw-online-dot"></span>
                                <span>Online</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="cw-header-right">
                    <button class="cw-hdr-btn" @onclick="ClearChat" title="New conversation" aria-label="New conversation">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="1 4 1 10 7 10" /><path d="M3.51 15a9 9 0 1 0 .49-3.51" />
                        </svg>
                    </button>
                    <button class="cw-hdr-btn" @onclick="CloseChat" title="Close" aria-label="Close chat">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                        </svg>
                    </button>
                </div>
            </div>

            @* Messages *@
            <div class="cw-messages" id="cw-messages">

                @if (_messages.Count == 0 && !_isStreaming)
                {
                    <div class="cw-welcome">
                        <div class="cw-welcome-emoji">&#x1F44B;</div>
                        <p>Hi! Ask me anything and I'll do my best to help.</p>
                        <div class="cw-chips">
                            @foreach (var p in _starterPrompts)
                            {
                                <button class="cw-chip" @onclick="() => UseStarter(p)">@p</button>
                            }
                        </div>
                    </div>
                }

                @foreach (var msg in _messages)
                {
                    @if (msg.Role == "user")
                    {
                        <div class="cw-row cw-row--user">
                            <div class="cw-bubble-user">@msg.Content</div>
                            <time class="cw-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</time>
                        </div>
                    }
                    else
                    {
                        <div class="cw-row cw-row--bot">
                            <div class="cw-bot-row">
                                <span class="cw-mini-av" aria-hidden="true">AI</span>
                                <div class="cw-bubble-bot">@msg.Content</div>
                            </div>
                            @if (msg.Citations.Count > 0)
                            {
                                <div class="cw-cit-wrap">
                                    <button class="cw-cit-toggle" @onclick="() => ToggleCit(msg.Id)">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                            <polyline points="14 2 14 8 20 8" />
                                        </svg>
                                        @msg.Citations.Count source@(msg.Citations.Count != 1 ? "s" : "")
                                        <span class="cw-arrow @(_openCit.Contains(msg.Id) ? "cw-arrow--open" : "")">&#x203A;</span>
                                    </button>
                                    @if (_openCit.Contains(msg.Id))
                                    {
                                        <ul class="cw-cit-list">
                                            @foreach (var c in msg.Citations)
                                            {
                                                <li class="cw-cit">
                                                    <span class="cw-cit-n">[@c.Index]</span>
                                                    @if (!string.IsNullOrEmpty(c.Url))
                                                    {
                                                        <a href="@c.Url" target="_blank" rel="noopener" class="cw-cit-link" title="@c.Excerpt">@c.Title</a>
                                                    }
                                                    else
                                                    {
                                                        <span class="cw-cit-title" title="@c.Excerpt">@c.Title</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(c.FilePath))
                                                    {
                                                        <span class="cw-cit-path">@c.FilePath</span>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }
                            <time class="cw-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</time>
                        </div>
                    }
                }

                @if (_isStreaming)
                {
                    <div class="cw-row cw-row--bot">
                        <div class="cw-bot-row">
                            <span class="cw-mini-av" aria-hidden="true">AI</span>
                            <div class="cw-bubble-bot cw-bubble-bot--live">
                                @_streamingText<span class="cw-cursor" aria-hidden="true">&#x2587;</span>
                            </div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="cw-error" role="alert">&#x26A0;&#xFE0F; @_error</div>
                }
            </div>

            @* Input bar *@
            <div class="cw-input-bar">
                <textarea class="cw-input"
                          @bind="_inputText"
                          @bind:event="oninput"
                          @onkeydown="HandleKey"
                          placeholder="Ask me anything&hellip; (Enter to send)"
                          rows="1"
                          maxlength="4000"
                          aria-label="Your message"></textarea>
                <button class="cw-send"
                        @onclick="SendMessage"
                        disabled="@(string.IsNullOrWhiteSpace(_inputText) || _isStreaming)"
                        title="Send (Enter)"
                        aria-label="Send">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13" />
                        <polygon points="22 2 15 22 11 13 2 9 22 2" />
                    </svg>
                </button>
            </div>

            <div class="cw-footer">USDA &middot; National Agricultural Statistics Service</div>
        </div>
    }

</div>

@code {
    private bool   _isOpen        = false;
    private bool   _isStreaming   = false;
    private bool   _hasUnread     = false;
    private string _inputText     = string.Empty;
    private string _streamingText = string.Empty;
    private string? _error;

    private List<ChatMessage> _messages = [];
    private HashSet<string>   _openCit  = [];
    private DotNetObjectReference<ChatWidget>? _dotnetRef;

    private readonly string[] _starterPrompts =
    [
        "What topics can you help me with?",
        "Give me a summary of available documents.",
        "What are the key policies I should know?"
    ];

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("chatWidget.abort"); } catch { }
        _dotnetRef?.Dispose();
    }

    private void OpenChat()  { _isOpen = true;  _hasUnread = false; }
    private async Task CloseChat() { _isOpen = false; await AbortAsync(); }

    private async Task ClearChat()
    {
        await AbortAsync();
        _messages.Clear(); _streamingText = string.Empty; _error = null; _openCit.Clear(); _isStreaming = false;
    }

    private async Task AbortAsync()
    {
        try { await JS.InvokeVoidAsync("chatWidget.abort"); } catch { }
        if (_isStreaming) { _isStreaming = false; _streamingText = string.Empty; }
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await SendMessage();
    }

    private async Task UseStarter(string text) { _inputText = text; await SendMessage(); }

    private async Task SendMessage()
    {
        var text = _inputText.Trim();
        if (string.IsNullOrWhiteSpace(text) || _isStreaming) return;

        _inputText = string.Empty; _error = null; _streamingText = string.Empty;

        var history = _messages.ToList(); // snapshot before adding new user message
        _messages.Add(new ChatMessage { Role = "user", Content = text });
        _isStreaming = true;

        await InvokeAsync(StateHasChanged);
        await ScrollBottomAsync();

        if (FoundryService.IsMock)
        {
            // Mock: call C# service directly — no JS/HTTP needed
            try
            {
                var result = await FoundryService.GetReplyAsync(history, text);
                if (result.Error is not null)
                    await ReceiveError(result.Error);
                else
                    await ReceiveDone(result.Reply ?? string.Empty, result.Citations);
            }
            catch (Exception ex) { await ReceiveError(ex.Message); }
        }
        else
        {
            // Real API: use JS fetch with word-by-word streaming
            var historyItems = history.Select(m => new { role = m.Role, content = m.Content }).ToList();
            var requestBody  = new { message = text, history = historyItems };
            _dotnetRef ??= DotNetObjectReference.Create(this);

            try { await JS.InvokeVoidAsync("chatWidget.sendMessage", requestBody, _dotnetRef, FoundryService.ApiAccessKey); }
            catch (JSException ex) { await ReceiveError($"JS error: {ex.Message}"); }
        }
    }

    [JSInvokable]
    public async Task ReceiveChunk(string chunk)
    {
        _streamingText += chunk;
        await InvokeAsync(StateHasChanged);
        await ScrollBottomAsync();
    }

    [JSInvokable]
    public async Task ReceiveDone(string fullReply, List<Citation>? citations)
    {
        _messages.Add(new ChatMessage
        {
            Role      = "assistant",
            Content   = string.IsNullOrWhiteSpace(fullReply) ? _streamingText : fullReply,
            Citations = citations ?? []
        });
        _streamingText = string.Empty; _isStreaming = false;
        if (!_isOpen) _hasUnread = true;
        await InvokeAsync(StateHasChanged);
        await ScrollBottomAsync();
    }

    [JSInvokable]
    public async Task ReceiveError(string error)
    {
        _messages.Add(new ChatMessage { Role = "assistant", Content = $"Error: {error}" });
        _streamingText = string.Empty; _isStreaming = false;
        if (!_isOpen) _hasUnread = true;
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleCit(string id) { if (!_openCit.Add(id)) _openCit.Remove(id); }

    private async Task ScrollBottomAsync()
    {
        try { await JS.InvokeVoidAsync("chatWidget.scrollToBottom", "cw-messages"); } catch { }
    }
}
